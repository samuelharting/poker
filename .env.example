# PartyKit configuration
# For local development, PartyKit runs on http://localhost:1999
# For production, set this to your deployed PartyKit URL
NEXT_PUBLIC_PARTYKIT_HOST=localhost:1999
# Example production:
# NEXT_PUBLIC_PARTYKIT_HOST=<your-partykit-name>.partykit.dev

# Optional: Set a custom party name (defaults to "main")
NEXT_PUBLIC_PARTY_NAME=main
